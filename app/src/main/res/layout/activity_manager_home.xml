<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    tools:context=".ManagerHomeActivity">

    <TextView
        android:id="@+id/tvManagerWelcomeMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="שלום מנהל מערכת"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="50dp"/>

    <Button
        android:id="@+id/btnAddStudent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ להוסיף תלמיד"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:textSize="18sp"/>

    <Button
        android:id="@+id/btnManagerActiveProblems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="תקלות פעילות"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:textSize="18sp"/>

    <Button
        android:id="@+id/btnManagerRaiseProblem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="העלת תקלה"
        android:layout_marginBottom="15dp"
        android:padding="15dp"
        android:textSize="18sp"/>

    <Button
        android:id="@+id/btnManagerFixedProblems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="תקלות שתוקנו"
        android:padding="15dp"
        android:textSize="18sp"/>

</LinearLayout>